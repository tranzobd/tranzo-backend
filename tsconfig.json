{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "rootDir": "src",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "types": ["node"],
    "ignoreDeprecations": "6.0"
  },
  "ts-node": {
    "transpileOnly": true
  },
  "include": ["src/**/*.ts"]
}
